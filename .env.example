# Copy to .env and fill in real values. NEVER commit the real .env.

# Server-side DEFAULT provider: mock | local | cloud
# The frontend sends a provider per request, so this is only the fallback default.
MODEL_PROVIDER=mock

# ── Local models (Xinference, OpenAI-compatible) ─────────────────────────
LOCAL_XINFERENCE_URL=http://localhost:9997
LOCAL_API_KEY=
LOCAL_IMAGE_MODEL=Z-Image-Turbo
LOCAL_VL_MODEL=qwen3.6-1
LOCAL_LLM_MODEL=qwen3.6-1

# ── Cloud models (OpenAI-compatible API, e.g. Agnes apihub) ──────────────
CLOUD_BASE_URL=https://apihub.agnes-ai.com/v1
CLOUD_API_KEY=
CLOUD_IMAGE_MODEL=agnes-image-2.1-flash
CLOUD_VL_MODEL=agnes-1.5-flash
CLOUD_TEXT_MODEL=agnes-2.0-flash

# ── Server ───────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
STORAGE_DIR=./data/pages
